.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  padding: 16rpx 24rpx 0;
  background: var(--bg);
  flex-shrink: 0;
}

.slogan {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.filters {
  white-space: nowrap;
  padding-bottom: 16rpx;
}

.filter-chip {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  background: #fff;
  color: var(--text-secondary);
  font-size: 26rpx;
  border: 2rpx solid var(--border);
}

.filter-chip.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  font-weight: 600;
}

.map-wrap {
  position: relative;
  height: 42vh;
  flex-shrink: 0;
}

.map {
  width: 100%;
  height: 100%;
}

.loc-btn {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.loc-icon {
  font-size: 36rpx;
  color: var(--primary);
}

.map-legend {
  position: absolute;
  left: 24rpx;
  bottom: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.green { background: #2ecc71; }
.dot.orange { background: #FF6B35; }
.dot.yellow { background: #f39c12; }

.list-panel {
  flex: 1;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.list-header {
  padding: 28rpx 32rpx 12rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-shrink: 0;
}

.list-title {
  font-size: 32rpx;
  font-weight: 700;
}

.list-sub {
  font-size: 24rpx;
  color: var(--text-muted);
}

.shop-list {
  flex: 1;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.shop-card {
  background: var(--bg);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.shop-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.shop-name {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  margin-left: 16rpx;
}

.shop-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.category {
  color: var(--text-secondary);
}

.shop-tags {
  margin-bottom: 12rpx;
}

.shop-tags .tag {
  margin-right: 8rpx;
}

.shop-items {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.dish {
  margin-right: 20rpx;
}

.empty-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}
