.page {
  padding: 24rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 8rpx 32rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35, #ff9a6c);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
}

.coin-card {
  background: linear-gradient(135deg, #ff6b35 0%, #ff9a6c 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.coin-label {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.coin-num {
  font-size: 72rpx;
  font-weight: 800;
  display: block;
  margin: 8rpx 0;
}

.coin-hint {
  font-size: 22rpx;
  opacity: 0.85;
}

.stats {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: var(--text-muted);
  font-size: 36rpx;
}

.footer-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 40rpx 20rpx;
  line-height: 1.6;
}
