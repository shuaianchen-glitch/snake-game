.page {
  padding: 24rpx 24rpx 160rpx;
}

.intro {
  background: linear-gradient(135deg, #ff6b35 0%, #ff9a6c 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.intro-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.intro-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 28rpx 28rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.field:last-child {
  border-bottom: none;
}

.label {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.input {
  font-size: 28rpx;
  padding: 16rpx 0;
}

.textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: var(--bg);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: var(--bg);
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.chip.active {
  background: var(--primary-light);
  color: var(--primary);
  border-color: var(--primary);
}

.loc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.loc-text {
  font-size: 26rpx;
  flex: 1;
}

.loc-text.muted {
  color: var(--text-muted);
}

.loc-pick {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.item-name {
  flex: 2;
}

.item-price {
  flex: 1;
  text-align: center;
}

.remove {
  width: 48rpx;
  height: 48rpx;
  text-align: center;
  line-height: 48rpx;
  color: var(--text-muted);
  font-size: 36rpx;
}

.add-item {
  color: var(--primary);
  font-size: 28rpx;
  padding: 12rpx 0;
}

.submit-btn {
  position: fixed;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
}
